# Copiá este archivo como config.env y completá los valores.
# No subas config.env al repositorio si contiene secretos.

# crear_vector_db.py usa embeddings locales de Chroma (sin llamadas a Groq/OpenAI).
# GROQ_* lo usás en un script aparte para el LLM (consultas RAG).

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
