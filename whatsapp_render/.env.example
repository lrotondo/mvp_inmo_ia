# MySQL (recomendado): mysql+pymysql://USER:PASS@HOST:3306/DB?charset=utf8mb4
# Postgres legacy (dev/migración): postgresql://...
DATABASE_URL=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_LEAD_MODEL=llama-3.1-8b-instant
# development | dev | local desactiva deteccion de leads
APP_ENV=production
# Mensajes previos enviados a Groq por chat (default 10 ≈ 5 turnos)
CHAT_HISTORY_MAX_MESSAGES=10
# Clasificacion de leads con Groq (requiere DATABASE_URL)
# false desactiva leads; en APP_ENV=development siempre off
LEAD_DETECTION_ENABLED=true
# WhatsApp del asesor/equipo para avisar leads (solo digitos, ej. 5492494123456)
LEAD_WHATSAPP_NOTIFY_TO=
# false desactiva el aviso por WhatsApp aunque LEAD_WHATSAPP_NOTIFY_TO este definido
LEAD_WHATSAPP_NOTIFY_ENABLED=true
META_VERIFY_TOKEN=
# App Secret de Meta: Configuracion de la app > Basica > Secreto de la aplicacion (NO el "Secreto del cliente" de Login)
META_APP_SECRET=
META_GRAPH_VERSION=v22.0
# Solo depuracion: 1 = no validar firma (NUNCA en produccion)
META_SKIP_SIGNATURE=0
# Fallback monotenant (si no hay fila en `tenants` o falta `phone_number_id` en el webhook)
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
# Google Sheets: opcional si las planillas son "cualquiera con el enlace" (Lector)
# Solo hace falta para planillas privadas sin acceso por enlace
GOOGLE_SERVICE_ACCOUNT_JSON=
# Alternativa local: ruta al archivo JSON de la cuenta de servicio
# GOOGLE_APPLICATION_CREDENTIALS=
# Segundos de cache en memoria para planillas Google (default 300)
CATALOG_CACHE_TTL_SECONDS=300
# Lista de espera: secreto para exportar CSV (header X-Admin-Secret)
WAITLIST_EXPORT_SECRET=
# Dias por defecto en GET /admin/waitlist/export.csv (default 7)
WAITLIST_EXPORT_DEFAULT_DAYS=7
